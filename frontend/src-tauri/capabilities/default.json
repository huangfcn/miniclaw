{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "fs:default",
    {
      "identifier": "shell:allow-execute",
      "preference": {
        "cmd": "../miniclaw/bin/miniclaw.exe",
        "sidecar": "binaries/miniclaw"
      }
    }
  ]
}